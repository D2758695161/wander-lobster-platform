# ============================================================
# 流浪龙虾平台 - 环境变量配置
# 复制此文件为 .env.local 并填写实际值
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
# 从 Supabase 项目 Settings → API 获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Supabase Edge Functions (Deno) ─────────────────────────
# 用于 verify-payment 和 release-payment 函数调用 Trongrid API
TRONGRID_API_KEY=your-trongrid-api-key  # https://trongrid.io 注册免费获取
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# ─── 平台配置 ───────────────────────────────────────────────
NEXT_PUBLIC_PLATFORM_URL=https://your-domain.com
NEXT_PUBLIC_PLATFORM_NAME="流浪龙虾"
PLATFORM_WALLET_TRC20=TPAPC39xtYjVNj1CQnqftXzJfi7BqCRnaN

# ─── Vercel (CI/CD 自动设置) ────────────────────────────────
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=team_xxxxxxxxxxxxx
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxx

# ─── 可选: 邮件 (SendGrid) ─────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxx
EMAIL_FROM=noreply@your-domain.com
