# ============================================================
# Environment Variables - 流浪龙虾平台
# Copy this to .env.local and fill in your values
# ============================================================

# Supabase Project URL (found in Supabase Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (found in Supabase Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (KEEP SECRET - only for Edge Functions)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: For local development with GitHub OAuth
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
